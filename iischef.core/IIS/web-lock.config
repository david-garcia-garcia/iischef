<?xml version="1.0" encoding="UTF-8"?>
<!--WHEN PLACE IN A DIRECTORY, THIS WEB.CONFIG WILL PREVENT ALL ACCESS-->
<configuration>
  <system.webServer>
    <security>
      <authorization>
        <clear/>
        <add accessType="Deny" users="*" roles="*"/>
      </authorization>
    </security>
  </system.webServer>
</configuration>
